        </mxCell>
        <mxCell id="TBjrdgxMKs7O-VZz0rv4-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Entrada" vertex="1">
