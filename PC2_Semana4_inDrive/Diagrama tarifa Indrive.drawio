        <mxCell id="TBjrdgxMKs7O-VZz0rv4-10" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=10;" value="nombre (cadena)&lt;div&gt;distancia (real)&lt;/div&gt;&lt;div&gt;hora de salida (entero)&lt;/div&gt;&lt;div&gt;tipo de vehiculo (entero)&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="140" x="160" y="-150" as="geometry" />
        </mxCell>
        <mxCell id="TBjrdgxMKs7O-VZz0rv4-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=10;" value="&lt;div&gt;Regla #1&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;subtotal&lt;/b&gt; = tarifabase + (costokm * km)&lt;/div&gt;&lt;div&gt;&lt;div&gt;Regla #2&lt;/div&gt;&lt;div&gt;Hora entre 7 y 9 o 17 y 20&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;subtotal &lt;/b&gt;= subtotal + (&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;subtotal *1.30&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;)&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Regla #3&lt;/div&gt;&lt;div&gt;Distancia &amp;gt; 15km&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;subtotal &lt;/b&gt;= subtotal + (&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;subtotal * 0.95&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Regla #4&lt;/div&gt;&lt;div&gt;No se puede tener un subtotal menor a 5.00&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Regla #5:&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Redondeo&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="265" x="337" y="-130" as="geometry" />
